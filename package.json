{
  "name": "fbtc-agent-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:required": "yarn workspace @functionfbtc/sdk-agent test && yarn workspace @functionfbtc/sdk-agentkit test && yarn workspace @functionfbtc/example-agent-chat test",
    "test:unit": "turbo run test:unit",
    "lint": "turbo run lint",
    "licenses:check": "node scripts/check-licenses.mjs",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-unused-imports": "^3.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.7.3",
    "typescript": "^5.4.5",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "packageManager": "yarn@4.9.1",
  "resolutions": {
    "axios": "1.12.0"
  }
}
