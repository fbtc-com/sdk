# Model provider used by the /api/chat serverless function.
# Supported values:
# - anthropic: uses ANTHROPIC_API_KEY and Claude models
# - glm: uses GLM_API_KEY/ZHIPUAI_API_KEY/ZAI_API_KEY and talks to GLM via either
#        the z.ai Anthropic-compatible gateway or an OpenAI-compatible gateway.
#        The protocol is auto-detected from GLM_BASE_URL (see below).
# MODEL_PROVIDER=anthropic

# Anthropic API key (used when MODEL_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional model override. The app defaults to claude-sonnet-4-6 for Anthropic
# and glm-5.2 for GLM.
# MODEL_NAME=claude-sonnet-4-6

# GLM / ZhipuAI setup (used when MODEL_PROVIDER=glm).
# Balance is per-gateway: pick the gateway your account has credits on.
#  - z.ai Anthropic gateway (recommended; credits usually live here):
#      GLM_BASE_URL=https://api.z.ai/api/anthropic
#    (a trailing /v1 is optional — the app appends it if missing)
#  - OpenAI-compatible gateway:
#      GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# A 1113 "insufficient balance" error means you are on the wrong gateway for
# this account, or the account needs a top-up.
MODEL_PROVIDER=glm
MODEL_NAME=glm-5.2
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://api.z.ai/api/anthropic

# WalletConnect project ID (get from https://cloud.walletconnect.com)
# MetaMask injected wallet can be used locally; WalletConnect requires this ID.
VITE_WALLETCONNECT_PROJECT_ID=your-project-id

# Ethereum mainnet RPC for server-side reads (get_token_balance).
# Without this, the API falls back to a public endpoint that often times out.
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<key>
