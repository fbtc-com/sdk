# Model provider:
# - anthropic: uses ANTHROPIC_API_KEY and Claude models
# - glm: uses GLM_API_KEY/ZHIPUAI_API_KEY/ZAI_API_KEY and talks to GLM via either
#        an Anthropic-compatible or OpenAI-compatible gateway.
#        The protocol is auto-detected from GLM_BASE_URL (see below).
MODEL_PROVIDER=glm

# Anthropic API key (used when MODEL_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional model override. Defaults: claude-sonnet-4-20250514 (anthropic), glm-5.2 (glm).
MODEL_NAME=glm-5.2

# GLM / ZhipuAI setup (used when MODEL_PROVIDER=glm).
# Anthropic-compatible (z.ai) — do NOT add /v1; LangChain's Anthropic SDK
# already posts to /v1/messages (unlike example-agent-chat's @ai-sdk/anthropic):
#   GLM_BASE_URL=https://api.z.ai/api/anthropic
# OpenAI-compatible (bigmodel.cn):
#   GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://api.z.ai/api/anthropic

# EVM private key (0x-prefixed). Generate a fresh testnet key, never use a key with real funds.
WALLET_PRIVATE_KEY=0x...

# Configure BOTH networks at startup. Tools select networkId from the user
# instruction; if the user does not name a network, default is ethereum-mainnet.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<key>
MANTLE_RPC_URL=https://rpc.mantle.xyz

# Wallet network for signing / supply (ethereum-mainnet | mantle-mainnet).
# Defaults to ethereum-mainnet when omitted.
NETWORK_ID=ethereum-mainnet
